{
  "expo": {
    "name": "Plate3D",
    "slug": "plate3d",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plate3d",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#14100c",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.plate3d.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Plate3D uses the camera to film your dishes for 3D menu models.",
        "NSMicrophoneUsageDescription": "Plate3D records audio as part of dish videos.",
        "NSPhotoLibraryUsageDescription": "Plate3D lets you pick dish photos and videos from your library."
      }
    },
    "android": {
      "package": "com.plate3d.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#14100c",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Plate3D uses the camera to film your dishes for 3D menu models.",
          "microphonePermission": "Plate3D records audio as part of dish videos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14100c",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2478ee53-8791-4910-be4c-4520a5eafa75"
      }
    },
    "owner": "malika_nish",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2478ee53-8791-4910-be4c-4520a5eafa75"
    }
  }
}
